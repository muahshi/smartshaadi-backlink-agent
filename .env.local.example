# SmartShaadi Backlink Agent — Environment Variables
# -------------------------------------------------------
# Copy this file: cp .env.local.example .env.local
# Then fill in your actual keys below

# ── GROQ API ──────────────────────────────────────────
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SERPER.DEV (Google Search API) ───────────────────
# Get free key: https://serper.dev  (2500 free/month)
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GITHUB TOKEN ──────────────────────────────────────
# Create at: https://github.com/settings/tokens/new
# Permissions: repo (read + write contents)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TARGET REPO ───────────────────────────────────────
# backlink_leads.md yahan save hogi
GITHUB_REPO_OWNER=muahshi
GITHUB_REPO_NAME=SmartShaadi.ai
